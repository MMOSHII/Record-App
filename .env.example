# =============================================================================
# FRONTEND (Vite) environment variables
# =============================================================================

# Google OAuth Client ID
# Get yours from https://console.cloud.google.com/apis/credentials
# REQUIRED for Google Sign-In (both web and Capacitor native)
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Backend API Base URL
# Leave unset (or empty) to use the Vite dev-server proxy, which forwards /api/* to
# http://localhost:8000 by default — ideal for local development (no CORS needed).
# Set this to a full URL to talk directly to a remote backend:
# VITE_API_BASE_URL=https://your-backend.example.com


# =============================================================================
# BACKEND (FastAPI / Python) environment variables
# =============================================================================

# JWT signing secret — REQUIRED, must be changed from this placeholder.
# Generate a strong value with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-in-production

# Google OAuth Client ID (same value as VITE_GOOGLE_CLIENT_ID, without the VITE_ prefix).
# Leave unset to disable Google Sign-In on the backend.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Personal API tokens for direct access (no registration required).
# Format: comma-separated "token:user_id" pairs.  The user_id part is optional
# and defaults to "api_user" when omitted.
#
# Examples:
#   Single token (user_id = api_user):
#     API_TOKENS=mysecrettoken123
#
#   Single token with a custom user_id (data stored under Data/hadi/):
#     API_TOKENS=mysecrettoken123:hadi
#
#   Multiple tokens:
#     API_TOKENS=token1:hadi,token2:guest
#
# Generate a strong token with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_TOKENS=

# SQLite database path (relative to where you start the server, or absolute).
# Defaults to auth.db in the current working directory.
# DB_PATH=auth.db

# Frontend base URL — used to build the password-reset link in emails.
# Defaults to http://localhost:5173 (Vite dev server).
# FRONTEND_URL=https://your-app.example.com
