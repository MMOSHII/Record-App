# =============================================================================
# FRONTEND (Vite) environment variables
# =============================================================================

# Google OAuth Client ID
# Get yours from https://console.cloud.google.com/apis/credentials
# REQUIRED for Google Sign-In (both web and Capacitor native)
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Backend API Base URL
# Leave unset (or empty) to use the Vite dev-server proxy, which forwards /api/* to
# http://localhost:8000 by default — ideal for local development (no CORS needed).
# Set this to a full URL to talk directly to a remote backend:
# VITE_API_BASE_URL=https://your-backend.example.com

# Public canonical site URL used for SEO metadata and sitemap entries.
# Example: https://record-note.example.com
VITE_SITE_URL=https://record-note.example.com

# =============================================================================
# BACKEND (FastAPI) CORS environment variables
# =============================================================================
#
# APP_ENV controls strictness. In production, wildcard origin (*) is rejected.
# APP_ENV=development
#
# Comma-separated list of allowed origins. Example:
# CORS_ALLOW_ORIGINS=https://app.example.com,https://admin.example.com
#
# Enable cookies/authorization headers in cross-origin requests.
# CORS_ALLOW_CREDENTIALS=true
#
# Allowed HTTP methods for CORS (OPTIONS is automatically ensured).
# CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
#
# Allowed request headers from browsers.
# CORS_ALLOW_HEADERS=Authorization,Content-Type,Accept,Origin,X-Requested-With
#
# Optional response headers exposed to browser JavaScript.
# CORS_EXPOSE_HEADERS=
#
# How long (seconds) browsers cache preflight responses.
# CORS_MAX_AGE=600
