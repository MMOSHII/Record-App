# Google OAuth Client ID
# Get yours from https://console.cloud.google.com/apis/credentials
# REQUIRED for Google Sign-In (both web and Capacitor native)
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Backend API Base URL
# Leave unset (or empty) to use the Vite dev-server proxy, which forwards /api/* to
# http://localhost:8000 by default — ideal for local development (no CORS needed).
# Set this to a full URL to talk directly to a remote backend:
# VITE_API_BASE_URL=https://your-backend.example.com
