# =========================================================
# Google OAuth
# =========================================================
# Your Google OAuth 2.0 client ID (required for Google sign-in)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# =========================================================
# Basic auth – JWT
# =========================================================
# REQUIRED: Change to a long, random string before deploying!
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_IN_PRODUCTION_USE_A_LONG_RANDOM_STRING

# How long a login session lasts (hours). Default: 24
JWT_EXPIRES_HOURS=24

# Path to the SQLite database that stores user accounts and reset tokens.
# Default: auth.db  (created automatically in the working directory)
AUTH_DB_PATH=auth.db

# =========================================================
# Password reset
# =========================================================
# Base URL of the frontend – used to build the reset link in emails.
# Example: https://yourapp.example.com
APP_BASE_URL=http://localhost:5173

# SMTP settings (optional).
# If not set, reset links are printed to the server console instead of emailed.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com

# =========================================================
# Storage
# =========================================================
# (no env var needed – data is stored in ./Data/ by default)
